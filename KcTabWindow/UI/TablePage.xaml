<Page
    x:Class="KcTabWindow.UI.TablePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:da="clr-namespace:KcTabWindow.ViewData"
    xmlns:local="clr-namespace:KcTabWindow.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="ComboBoxItemTemplate">
            <StackPanel Orientation="Horizontal">
                <ui:TextBlock Foreground="Azure" Text="{Binding Week}" />
            </StackPanel>
        </DataTemplate>

        <!--  居中样式的 DataTemplate  -->
        <DataTemplate x:Key="CenteredCellTemplate">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="{Binding}"
                    TextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="21,0,21,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <ui:Button
                    Margin="0,0,13,0"
                    VerticalAlignment="Center"
                    Click="jietu_Click"
                    Content="截图"
                    Icon="Fluent24" />
                <ComboBox x:Name="zhoubox" Margin="0,0,13,0" />
                <ui:TextBlock
                    x:Name="itemtext"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="当前时间" />
            </StackPanel>

        </Grid>
        <ScrollViewer
            x:Name="scrollViewer"
            Grid.Row="1"
            Padding="13,13,13,16"
            HorizontalScrollBarVisibility="Auto"
            PreviewMouseWheel="ScrollViewer_MouseWheel"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <!--<DataGrid CellMouseDown />-->
                <ui:DataGrid
                    x:Name="datagrid"
                    Padding="0,3,10,10"
                    AutoGenerateColumns="False"
                    Background="#2d2d2d"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    PreviewMouseDown="datagrid_PreviewMouseDown"
                    RowHeight="90"
                    SelectionMode="Extended"
                    SelectionUnit="Cell">
                    <ui:DataGrid.Resources>
                        <!--  定义居中对齐的标题样式  -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Content" Value="{Binding}" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ui:DataGrid.Resources>
                    <ui:DataGrid.ItemTemplate>
                        <DataTemplate>
                            <StackPanel />
                        </DataTemplate>
                    </ui:DataGrid.ItemTemplate>

                    <ui:DataGrid.Columns />
                </ui:DataGrid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
