<Application
    x:Class="KcTabWindow.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:KcTabWindow.ViewData"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    DispatcherUnhandledException="OnDispatcherUnhandledException"
    Exit="OnExit"
    Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <!--  引入 WPFUI 默认资源  -->
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <!--  全局 TextBlock 样式  -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White" />
            </Style>
            <!--  全局ListBoxItem样式，去除点击效果  -->
            <Style x:Key="ListBoxItemButton" TargetType="ListBoxItem">
                <!--  禁用默认的选中效果  -->
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!--  移除选中时的视觉反馈  -->
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Trigger>
                    <!--  可选：移除鼠标悬停时的效果  -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <DataTemplate x:Key="SectionCellTemplate">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        Text="{Binding Section}" />
                    <TextBlock
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="#dcdcdc"
                        Text="{Binding StartTime}" />
                    <TextBlock
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="#dcdcdc"
                        Text="{Binding EndTime}" />
                </Grid>
            </DataTemplate>

            <local:CourseIndexConverter x:Key="CourseIndexConverter" />
            <DataTemplate x:Key="InfoTabs">
                <Grid>
                    <TextBlock
                        Margin="3,0,3,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="{Binding Courses, Converter={StaticResource CourseIndexConverter}}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </Grid>
            </DataTemplate>
        </ResourceDictionary>



    </Application.Resources>
</Application>
